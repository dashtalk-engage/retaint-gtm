        "accountId": "0", "containerId": "0", "variableId": "12", "name": "CJS - Retaint Product IDs",
        "type": "jsm", "parentFolderId": "1", "fingerprint": "0",
        "notes": "Flattens ecommerce.items[] into an array of item_id strings for the 'buy' event.",
        "parameter": [
          { "type": "TEMPLATE", "key": "javascript", "value": "function(){var items={{DLV - ecommerce.items}}||[];var out=[];for(var i=0;i<items.length;i++){var id=items[i]&&(items[i].item_id||items[i].id);if(id)out.push(String(id));}return out;}" }
        ]
      },
      {
        "accountId": "0", "containerId": "0", "variableId": "13", "name": "CJS - Retaint Checkout Payload",
        "type": "jsm", "parentFolderId": "1", "fingerprint": "0",
        "notes": "Builds the checkoutstarted payload from GA4 ecommerce dataLayer: {pageUrl, totalOrderValue, itemCount, items:[{productId,quantity}]}.",
        "parameter": [
          { "type": "TEMPLATE", "key": "javascript", "value": "function(){var items={{DLV - ecommerce.items}}||[];var mapped=[];var total=0;for(var i=0;i<items.length;i++){var it=items[i]||{};var pid=it.item_id||it.id||'';var qty=it.quantity||1;if(pid)mapped.push({productId:String(pid),quantity:Number(qty)});total+=Number(qty);}return {pageUrl:{{Page URL}},totalOrderValue:String({{DLV - ecommerce.value}}||''),itemCount:total,items:mapped};}" }
        ]
      },
