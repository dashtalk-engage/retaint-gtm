        "accountId": "0", "containerId": "0", "variableId": "11", "name": "CJS - Retaint Product Reference",
        "type": "jsm", "parentFolderId": "1", "fingerprint": "0",
        "notes": "Fallback chain for productview/addtocart eventVal: item_url -> item_id -> Page URL.",
        "parameter": [
          { "type": "TEMPLATE", "key": "javascript", "value": "function(){var u={{DLV - ecommerce.items.0.item_url}};if(u)return u;var i={{DLV - ecommerce.items.0.item_id}};if(i)return i;return {{Page URL}};}" }
